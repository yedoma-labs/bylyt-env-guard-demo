# Server Configuration
PORT=3000
HOST=localhost
NODE_ENV=development

# Application
APP_NAME=bylyt-env-guard-demo
APP_VERSION=0.1.0

# Security
API_KEY=your-secret-api-key-here

# Logging
LOG_LEVEL=info

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Limits
MAX_REQUEST_SIZE_KB=1024

# Features
ENABLE_DOCS=true
